{
  "name": "multitable",
  "version": "0.0.1",
  "description": "A terminal multiplexer for the agentic coding age",
  "keywords": [
    "terminal",
    "multiplexer",
    "agent",
    "claude",
    "coding",
    "cli"
  ],
  "homepage": "https://multitable.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/multitable-dev/multitable.git"
  },
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n daemon,web -c blue,magenta \"npm run dev -w @multitable/daemon\" \"npm run dev -w @multitable/web\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "format": "prettier --write packages/*/src"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0"
  }
}
