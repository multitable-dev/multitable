    "env-paths": "^2.0.0",
    "express": "^4.19.0",
    "glob": "^10.3.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.24.0",
    "uuid": "^9.0.0",
    "ws": "^8.17.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
